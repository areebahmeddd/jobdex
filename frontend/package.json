    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.101.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
