# App settings
APP_NAME=JobDex API
APP_VERSION=1.0.0
DEBUG=false

# Database settings
DATABASE_URL=postgresql+psycopg2://user:pass@host/neondb?sslmode=require
DB_ECHO=false

# ATS crawl settings
HTTP_TIMEOUT=30.0
CRAWL_DELAY=0.3

# Resolve unknown cities via Nominatim (OpenStreetMap)
GEOCODE_UNKNOWN_CITIES=false
GEOCODE_USER_AGENT=JobDex/1.0 (+https://github.com/<github-username>/jobdex)

# Require X-API-Key header on /ingest/* and /admin/* routes
# Generate a secure random key with: openssl rand -hex 32
# ADMIN_API_KEY=your-key-here
