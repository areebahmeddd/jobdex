# App settings
APP_NAME=JobDex API
APP_VERSION=1.0.0
DEBUG=false

# Database settings
DATABASE_URL=postgresql+psycopg2://user:pass@host/neondb?sslmode=require
DB_ECHO=false
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=3
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=600

# ATS crawl settings
HTTP_TIMEOUT=30.0
CRAWL_DELAY=0.3

# Scheduler settings
INGEST_INTERVAL_HOURS=6
ENRICH_INTERVAL_HOURS=12
DISCOVER_INTERVAL_HOURS=24

# Unknown city resolution (Nominatim + OpenStreetMap)
GEOCODE_UNKNOWN_CITIES=false
GEOCODE_USER_AGENT=JobDex/1.0 (+https://github.com/<github-username>/jobdex)

# Company enrichment (Wikidata + Wikipedia)
ENRICHMENT_BOT_AGENT=JobDex/1.0 (+https://github.com/<github-username>/jobdex)
ENRICHMENT_REQUEST_TIMEOUT=15.0
ENRICHMENT_STEP_DELAY=0.5

# Razorpay payment gateway
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=key_secret
